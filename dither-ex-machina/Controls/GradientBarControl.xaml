<UserControl x:Class="dither_ex_machina.Controls.GradientBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Border x:Name="GradientPreviewBorder" Height="36"
                BorderBrush="Gray" BorderThickness="1"
                MouseLeftButtonDown="GradientPreviewBorder_MouseLeftButtonDown"
                Cursor="Hand"
                ToolTip="Клик - добавить точку градиента"/>

        <Canvas x:Name="MarkersCanvas" Height="16" Background="Transparent" Margin="0,2,0,0"/>

        <Grid x:Name="SelectedStopPanel" Margin="0,10,0,0" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="SelectedColorSwatch" Grid.Column="0"
                    Width="24" Height="24" BorderBrush="Gray" BorderThickness="1"
                    Margin="0,0,8,0" Cursor="Hand"
                    ToolTip="Клик - изменить цвет"
                    MouseLeftButtonDown="SelectedColorSwatch_MouseLeftButtonDown"/>

            <TextBlock Grid.Column="1" Text="Позиция, %:" VerticalAlignment="Center" Margin="0,0,5,0"/>

            <TextBox x:Name="PositionTextBox" Grid.Column="2" Width="50" VerticalAlignment="Center"
                     LostFocus="PositionTextBox_LostFocus" KeyDown="PositionTextBox_KeyDown"/>

            <Button x:Name="DeleteStopButton" Grid.Column="4" Content="Удалить точку"
                    HorizontalAlignment="Right" Click="DeleteStopButton_Click"/>
        </Grid>
    </StackPanel>
</UserControl>