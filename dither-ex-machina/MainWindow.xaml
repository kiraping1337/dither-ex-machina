<Window x:Class="dither_ex_machina.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dither_ex_machina"
        xmlns:controls="clr-namespace:dither_ex_machina.Controls"
        mc:Ignorable="d"
        Title="Dither Ex Machina" Height="800" Width="1100">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#222" Margin="5">
            <Image x:Name="PreviewImage" Stretch="Uniform"/>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">
                <Button Content="Открыть..." Click="OpenButton_Click" Margin="0,0,0,5"/>
                <Button Content="Сохранить..." Click="SaveButton_Click" Margin="0,0,0,15"/>

                <TextBlock Text="Режим эффекта" FontWeight="Bold"/>
                <ComboBox x:Name="ModeComboBox"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="ModeComboBox_SelectionChanged"
                          Margin="0,5,0,15"/>

                <StackPanel x:Name="EffectParametersPanel"/>

                <Separator Margin="0,15,0,10"/>
                <TextBlock Text="Общая предобработка" FontWeight="Bold"/>

                <TextBlock Text="Устранение JPEG-блочности (медиана)" Margin="0,10,0,0"/>
                <Slider x:Name="MedianRadiusSlider" Minimum="0" Maximum="8" Value="3"
                        ValueChanged="Param_Changed"/>
                <TextBlock Text="{Binding ElementName=MedianRadiusSlider, Path=Value, StringFormat=F0}"/>

                <TextBlock Text="Сглаживание (blur radius)" Margin="0,10,0,0"/>
                <Slider x:Name="BlurRadiusSlider" Minimum="0" Maximum="15" Value="3"
                        ValueChanged="Param_Changed"/>
                <TextBlock Text="{Binding ElementName=BlurRadiusSlider, Path=Value, StringFormat=F0}"/>

                <TextBlock Text="Обрезка чёрного (тени)" Margin="0,10,0,0"/>
                <Slider x:Name="CutoffSlider" Minimum="0" Maximum="0.5" Value="0.05"
                        ValueChanged="Param_Changed"/>
                <TextBlock Text="{Binding ElementName=CutoffSlider, Path=Value, StringFormat=F2}"/>

                <TextBlock Text="Обрезка белого (блики)" Margin="0,10,0,0"/>
                <Slider x:Name="HighlightCutoffSlider" Minimum="0.5" Maximum="1" Value="0.92"
                        ValueChanged="Param_Changed"/>
                <TextBlock Text="{Binding ElementName=HighlightCutoffSlider, Path=Value, StringFormat=F2}"/>

                <Separator Margin="0,15,0,10"/>
                <TextBlock Text="Контраст (борьба с фоном)" FontWeight="Bold"/>

                <TextBlock Text="Центр объекта (яркость)" Margin="0,10,0,0"/>
                <Slider x:Name="ContrastCenterSlider" Minimum="0" Maximum="1" Value="0.5"
                        ValueChanged="Param_Changed"/>
                <TextBlock Text="{Binding ElementName=ContrastCenterSlider, Path=Value, StringFormat=F2}"/>

                <TextBlock Text="Крутизна (подавление фона)" Margin="0,10,0,0"/>
                <Slider x:Name="ContrastSteepnessSlider" Minimum="0.5" Maximum="15" Value="1"
                        ValueChanged="Param_Changed"/>
                <TextBlock Text="{Binding ElementName=ContrastSteepnessSlider, Path=Value, StringFormat=F2}"/>

                <TextBlock Text="Сглаживание после контраста" Margin="0,10,0,0"/>
                <Slider x:Name="PostContrastSmoothSlider" Minimum="0" Maximum="10" Value="2"
                        ValueChanged="Param_Changed"/>
                <TextBlock Text="{Binding ElementName=PostContrastSmoothSlider, Path=Value, StringFormat=F0}"/>

                <Separator Margin="0,15,0,10"/>

                <TextBlock Text="Суперсэмплинг" Margin="0,10,0,0"/>
                <Slider x:Name="SupersampleSlider" Minimum="1" Maximum="4" Value="3"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        ValueChanged="Param_Changed"/>
                <TextBlock Text="{Binding ElementName=SupersampleSlider, Path=Value, StringFormat=F0}"/>
                <Separator Margin="0,15,0,10"/>
                <CheckBox x:Name="GradientMapEnabledCheckBox" Content="Использовать Gradient Map"
                          Checked="GradientMapEnabledCheckBox_Changed"
                          Unchecked="GradientMapEnabledCheckBox_Changed"/>
                <controls:GradientBarControl x:Name="GradientEditor" Margin="0,10,0,0"
                              Visibility="Collapsed"
                              GradientChanged="GradientEditor_GradientChanged"/>
                <CheckBox x:Name="InvertCheckBox" Content="Инвертировать" Margin="0,15,0,0"
                          Checked="Param_Changed" Unchecked="Param_Changed"/>

                <CheckBox x:Name="GlowEnabledCheckBox" Content="Glow" Margin="0,15,0,0"
                          Checked="GlowEnabledCheckBox_Changed" Unchecked="GlowEnabledCheckBox_Changed"/>
                <StackPanel x:Name="GlowControlsPanel" Visibility="Collapsed">
                    <TextBlock Text="Радиус" Margin="0,10,0,0"/>
                    <Slider x:Name="GlowRadiusSlider" Minimum="1" Maximum="30" Value="8"
                            ValueChanged="Param_Changed"/>
                    <TextBlock Text="{Binding ElementName=GlowRadiusSlider, Path=Value, StringFormat=F0}"/>

                    <TextBlock Text="Порог" Margin="0,10,0,0"/>
                    <Slider x:Name="GlowThresholdSlider" Minimum="0" Maximum="1" Value="0.6"
                            ValueChanged="Param_Changed"/>
                    <TextBlock Text="{Binding ElementName=GlowThresholdSlider, Path=Value, StringFormat=F2}"/>

                    <TextBlock Text="Интенсивность" Margin="0,10,0,0"/>
                    <Slider x:Name="GlowIntensitySlider" Minimum="0" Maximum="2" Value="0.8"
                            ValueChanged="Param_Changed"/>
                    <TextBlock Text="{Binding ElementName=GlowIntensitySlider, Path=Value, StringFormat=F2}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>